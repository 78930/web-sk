# Sketu web — development environment
#
# VITE_API_PROXY_TARGET: Vite proxies /api/* to this URL in dev
#   so the browser never hits CORS issues on localhost.
# VITE_API_BASE_URL: leave empty so the dev proxy is used (not direct fetch).
#   For Vercel / production builds, set VITE_API_BASE_URL=https://my-1-1iz4.onrender.com

VITE_API_PROXY_TARGET=http://localhost:5000
VITE_API_BASE_URL=
