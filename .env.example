# Base URL of the Sketu Express backend.
# Leave empty to use the Vite dev proxy (requests to /api are forwarded to
# VITE_API_PROXY_TARGET, default http://localhost:5000).
# For production builds, set this to your deployed API origin, e.g.
# VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=

# Used only by the dev server proxy (vite.config.js). Not exposed to the client.
VITE_API_PROXY_TARGET=http://localhost:5000
